frontend/src/**/*.js
frontend/src/**/*.d.ts
frontend/vite.config.js
frontend/vite.config.d.ts

# editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*

# env
.env
.env.local
.env.*.local

# test snapshots (just in case)
*.shot.png

# development screenshots
frontend-*.png
