# ============================================================
# selflearn-backend 环境变量模板
# 复制为 .env 后按需修改；不要把 .env 提交进 git。
#
# 默认值面向 host（localhost），便于本地直接跑：
#   uv run alembic upgrade head
#   uv run python -m scripts.seed_dev
#   uv run pytest
# 容器内由 docker-compose.yml 的 environment 覆盖为服务名。
# ============================================================

# ---------- 日志 ----------
LOG_LEVEL=INFO

# ---------- PostgreSQL (host-side localhost; compose 覆盖为 postgres) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=selflearn
POSTGRES_PASSWORD=selflearn_dev
POSTGRES_DB=selflearn
# 由上面四项拼接得到（config.py 内组装）
# POSTGRES_DSN=postgresql+asyncpg://selflearn:selflearn_dev@localhost:5432/selflearn

# ---------- Redis (host-side localhost; compose 覆盖为 redis:6379) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Qdrant (host-side localhost; compose 覆盖为 http://qdrant:6333) ----------
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                # 本地默认不开鉴权，留空

# ---------- MinIO (host-side localhost; compose 覆盖为 minio:9000) ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=selflearn_minio
MINIO_SECRET_KEY=selflearn_minio_dev
MINIO_BUCKET=selflearn
MINIO_SECURE=false

# ---------- RabbitMQ (host-side localhost; compose 覆盖为 rabbitmq) ----------
RABBITMQ_URL=amqp://selflearn:selflearn_dev@localhost:5672/

# ---------- OpenTelemetry / Jaeger (host-side localhost; compose 覆盖为 jaeger) ----------
# OTLP gRPC → Jaeger（4317 端口）
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=selflearn-backend
# OTEL_TRACES_SAMPLER=parentbased_always_on

# ---------- LLM 抽象层 ----------
# 默认 provider：mock | openai_compat | ifly_spark
LLM_DEFAULT_PROVIDER=mock

# OpenAI 兼容 provider（如 DeepSeek / OpenAI / 本地 vLLM）
LLM_OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
LLM_OPENAI_COMPAT_API_KEY=sk-replace-me
LLM_OPENAI_COMPAT_MODEL=deepseek-chat
# LLM_OPENAI_COMPAT_TIMEOUT=30

# ---------- Gateway ----------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000